BOT_TOKEN=
BOOP_API_URL=http://localhost:3000   # base URL of the boop.fish site server
CHEST_INFO_CHANNEL_ID=
CHEST_INFO_MESSAGE_ID=
CHEST_EVENTS_FILE=chest_events.json
DATABASE_URL=postgres://boop:yourpassword@localhost:5432/boopfish
BRAIN_BASE_URL=http://10.8.0.200:8000
BRAIN_SHARED_SECRET=changeme
JUMPIN_ENABLED=true
JUMPIN_MESSAGE_INTERVAL=10
JUMPIN_COOLDOWN_SECONDS=300
LORE_SUMMARIZE_GAP_MINUTES=30         # default silence gap marking a conversation boundary - overridable per-command via !lore summarize [hours_ago] [gap_minutes]
LORE_SUMMARIZE_MAX_LOOKBACK_HOURS=48  # hard cap on how far back !lore summarize will look behind its anchor point, regardless of gaps - not overridable per-command
LORE_SUMMARIZE_MAX_MESSAGES=500       # max messages fetched from Discord history per !lore summarize call - not overridable per-command